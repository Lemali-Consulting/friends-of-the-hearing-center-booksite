---
import { base } from '../utils/url.js';

interface Props {
  title: string;
  showBackLink?: boolean;
}

const { title, showBackLink = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="A curated catalog of 800+ books featuring Deaf, Hard of Hearing, and DeafBlind characters, maintained by Friends of the Hearing Center at UPMC Children's Hospital of Pittsburgh." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="page-bg" aria-hidden="true"></div>

    <header>
      <div class="header-inner">
        {showBackLink ? (
          <a href={`${base}/`} class="back-link">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All books
          </a>
        ) : (
          <div class="logo-row">
            <img class="logo-img" src={`${base}/image.png`} alt="Friends of the Hearing Center logo" />
            <div>
              <h1><a href={`${base}/`}>Friends of the Hearing Center</a></h1>
              <p class="subtitle">Books featuring Deaf, Hard of Hearing &amp; DeafBlind characters</p>
            </div>
          </div>
        )}
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p>Created by <a href="https://lemaliconsulting.com" class="lemali-link"><img src={`${base}/lemali-logo.svg`} alt="Lemali Consulting" class="lemali-logo" /></a> for UPMC Children's Hospital of Pittsburgh</p>
      </div>
    </footer>
  </body>
</html>

<style>
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 1000;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-body);
  }

  .skip-link:focus {
    top: 0;
  }

  :root {
    --color-cream: #F7F5F0;
    --color-cream-dark: #EDEAE3;
    --color-card: #FDFCFA;
    --color-ink: #1A1A2E;
    --color-ink-light: #3D3D56;
    --color-ink-muted: #7A7A8E;
    --color-navy: #1B3F8B;
    --color-navy-soft: #E0E7F5;
    --color-accent: #1B3F8B;
    --color-accent-soft: #E0E7F5;
    --color-teal: #6ECFD0;
    --color-teal-dark: #3BAFB0;
    --color-teal-soft: #E0F5F5;
    --color-plum: #9B4DCA;
    --color-plum-soft: #F0E3FA;
    --color-border: #DDD9D1;
    --color-border-light: #E8E5DF;

    --font-display: 'Fraunces', 'Georgia', serif;
    --font-body: 'Outfit', system-ui, sans-serif;

    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;

    --shadow-card: 0 1px 3px rgba(26, 26, 46, 0.06), 0 4px 12px rgba(26, 26, 46, 0.04);
    --shadow-card-hover: 0 4px 12px rgba(26, 26, 46, 0.08), 0 12px 32px rgba(26, 26, 46, 0.08);
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: var(--font-body);
    background: var(--color-cream);
    color: var(--color-ink);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
  }

  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 50% at 20% 0%, rgba(27, 63, 139, 0.04), transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(110, 207, 208, 0.06), transparent 50%),
      var(--color-cream);
  }

  header {
    background: rgba(255, 252, 247, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-light);
    padding: 1.25rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
    animation: fadeInDown 0.5s ease;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo-img {
    height: 48px;
    width: auto;
    flex-shrink: 0;
  }

  h1 {
    margin: 0 0 0.15rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.15;
    font-optical-sizing: auto;
  }

  h1 a {
    color: inherit;
    text-decoration: none;
  }

  h1 a:hover {
    color: var(--color-accent);
  }

  .subtitle {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    flex: 1;
    width: 100%;
  }

  footer {
    text-align: center;
    padding: 2rem 1.5rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    border-top: 1px solid var(--color-border-light);
    background: rgba(255, 252, 247, 0.6);
    letter-spacing: 0.01em;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  footer p {
    margin: 0;
  }

  footer a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  footer a:hover {
    text-decoration: underline;
  }

  .lemali-link {
    text-decoration: none;
  }

  .lemali-link:hover {
    text-decoration: none;
  }

  .lemali-logo {
    display: inline-block;
    height: 1.6em;
    width: auto;
    vertical-align: middle;
    position: relative;
    top: -0.1em;
  }
</style>
