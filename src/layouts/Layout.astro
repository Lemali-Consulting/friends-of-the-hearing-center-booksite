---
import { base } from '../utils/url.js';

interface Props {
  title: string;
  showBackLink?: boolean;
  isLanding?: boolean;
}

const { title, showBackLink = false, isLanding = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="A curated catalog of 800+ books featuring Deaf, Hard of Hearing, and DeafBlind characters, maintained by Hearing Center Book Catalog." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      if (location.search) document.documentElement.classList.add('catalog-loading');
    </script>
    <style is:inline>
      .catalog-loading .catalog { visibility: hidden; }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="page-bg" aria-hidden="true"></div>

    <header>
      <nav aria-label="Site">
        <div class="header-inner">
          {showBackLink ? (
            <div class="header-row">
              <a href={`${base}/books`} class="back-link">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                All books
              </a>
            </div>
          ) : (
            <div class="header-row">
              <div class="logo-row">
                <img class="logo-img" src={`${base}/image.png`} alt="Hearing Center Book Catalog logo" />
                <div>
                  <h1><a href={`${base}/`}>Hearing Center Book Catalog</a></h1>
                  <p class="subtitle">
                    <span class="subtitle-icons" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 3.5C5.5 2 7.5 1.5 9 3c1 1 1 2.5.5 4-.5 1.2-1.5 2-2 3-.5.8-.5 1.5-.5 2"/><path d="M10 2.5c.5-.3 1.2-.2 1.5.2s.5 1.5 0 2.5l-.5 1"/><circle cx="7" cy="12" r=".7" fill="currentColor" stroke="none"/></svg>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9V5.5a1 1 0 0 1 2 0V8"/><path d="M6 7V4.5a1 1 0 0 1 2 0V8"/><path d="M8 7V5a1 1 0 0 1 2 0v3.5c0 2-1.5 3.5-3.5 3.5S3 11 3 10"/></svg>
                    </span>
                    Books featuring Deaf, Hard of Hearing &amp; DeafBlind characters
                  </p>
                </div>
              </div>
              {!isLanding && (
                <a href={`${base}/books`} class="nav-link">Browse Catalog</a>
              )}
            </div>
          )}
        </div>
      </nav>
    </header>

    {showBackLink && (
      <script is:inline>
        {
          const link = document.querySelector('.back-link');
          const qs = sessionStorage.getItem('catalogQuery');
          if (link && qs) {
            const href = link.getAttribute('href').split('?')[0];
            link.href = href + '?' + qs;
          }
        }
      </script>
    )}

    <main id="main-content">
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p>Created by <a href="https://lemaliconsulting.com" class="lemali-link"><img src={`${base}/lemali-logo.svg`} alt="Lemali Consulting" class="lemali-logo" /></a> for Hearing Center Book Catalog</p>
      </div>
    </footer>
  </body>
</html>

<style>
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 1000;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-body);
  }

  .skip-link:focus {
    top: 0;
  }

  :root {
    --color-cream: #F7F5F0;
    --color-cream-dark: #EDEAE3;
    --color-card: #FDFCFA;
    --color-ink: #1A1A2E;
    --color-ink-light: #3D3D56;
    --color-ink-muted: #5C5C6F;
    --color-navy: #1B3F8B;
    --color-navy-soft: #E0E7F5;
    --color-accent: #1B3F8B;
    --color-accent-soft: #E0E7F5;
    --color-teal: #1A8A8B;
    --color-teal-dark: #1A8A8B;
    --color-teal-soft: #E0F5F5;
    --color-plum: #7B2FA8;
    --color-plum-soft: #F0E3FA;
    --color-gold: #8B6914;
    --color-gold-soft: #F5EFD8;
    --color-border: #DDD9D1;
    --color-border-light: #E8E5DF;

    --font-display: 'Fraunces', 'Georgia', serif;
    --font-body: 'Outfit', system-ui, sans-serif;

    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;

    --shadow-card: 0 1px 3px rgba(26, 26, 46, 0.06), 0 4px 12px rgba(26, 26, 46, 0.04);
    --shadow-card-hover: 0 4px 12px rgba(26, 26, 46, 0.08), 0 12px 32px rgba(26, 26, 46, 0.08);
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: var(--font-body);
    background: var(--color-cream);
    color: var(--color-ink);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
  }

  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 50% at 20% 0%, rgba(27, 63, 139, 0.04), transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(110, 207, 208, 0.06), transparent 50%),
      var(--color-cream);
  }

  header {
    background: rgba(255, 252, 247, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-light);
    padding: 1.25rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
    animation: fadeInDown 0.5s ease;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    padding: 0.4rem 0.85rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .logo-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo-img {
    height: 48px;
    width: auto;
    flex-shrink: 0;
  }

  h1 {
    margin: 0 0 0.15rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.15;
    font-optical-sizing: auto;
  }

  h1 a {
    color: inherit;
    text-decoration: none;
  }

  h1 a:hover {
    color: var(--color-accent);
  }

  .subtitle {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .subtitle-icons {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    color: var(--color-teal-dark);
    opacity: 0.7;
  }

  .subtitle-icons svg {
    display: block;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    flex: 1;
    width: 100%;
  }

  footer {
    text-align: center;
    padding: 2rem 1.5rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    border-top: 1px solid var(--color-border-light);
    background: rgba(255, 252, 247, 0.6);
    letter-spacing: 0.01em;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  footer p {
    margin: 0;
  }

  footer a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  footer a:hover {
    text-decoration: underline;
  }

  .lemali-link {
    text-decoration: none;
  }

  .lemali-link:hover {
    text-decoration: none;
  }

  .lemali-logo {
    display: inline-block;
    height: 2.4em;
    width: auto;
    vertical-align: middle;
    position: relative;
    top: -0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
