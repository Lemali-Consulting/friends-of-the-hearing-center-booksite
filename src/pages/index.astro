---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/url.js';
import { featuredBookIds } from '../data/featured.js';
import { getTagIconSvg } from '../utils/tag-icons';

const bookEntries = await getCollection('books');
const metadataEntries = await getCollection('metadata');
const metadataMap = new Map(metadataEntries.map(c => [c.id, c.data]));

const bookMap = new Map(bookEntries.map(entry => [entry.id, entry]));

function toFeatured(entry) {
  const meta = metadataMap.get(entry.id);
  return {
    id: entry.id,
    ...entry.data,
    coverImage: entry.data.coverImage || meta?.coverUrl || null,
  };
}

const landingPageBooks = bookEntries.filter(entry => entry.data.landingPage);

const featuredBooks = landingPageBooks.length > 0
  ? landingPageBooks.map(toFeatured)
  : featuredBookIds.map(id => bookMap.get(id)).filter(Boolean).map(toFeatured);

const totalBooks = bookEntries.length;
---

<Layout title="Hearing Center Book Catalog" isLanding>
  <section class="hero">
    <h2 class="hero-heading">Discover Stories That Reflect Every&nbsp;Child</h2>
    <p class="hero-text">
      Explore our curated collection of <strong>{totalBooks}+ books</strong> featuring Deaf, Hard of Hearing, and DeafBlind characters.
    </p>
    <a href={`${base}/books`} class="cta-button">
      Browse the Full Catalog
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7.5 5L12.5 10L7.5 15"/>
      </svg>
    </a>
  </section>

  <section class="featured">
    <h2 class="section-heading">Featured Books</h2>
    <div class="featured-grid">
      {featuredBooks.map(book => (
        <a href={`${base}/books/${book.id}`} class="book-card">
          <div class="cover">
            {book.coverImage
              ? <img src={book.coverImage} alt={`Cover of ${book.title}`} loading="lazy" />
              : <div class="cover-placeholder" aria-hidden="true">{book.title[0]}</div>
            }
          </div>
          <div class="info">
            <h3 class="card-title">{book.title}</h3>
            <p class="card-author">{book.author}</p>
            <div class="card-meta">
              {book.ageGroups.length > 0 && <span>{book.ageGroups.join(' / ')}</span>}
              {book.ageGroups.length > 0 && book.bookType && <span class="dot">&middot;</span>}
              {book.bookType && <span>{book.bookType}</span>}
            </div>
            <div class="card-tags">
              {book.mainCharacter && (
                <span class="tag tag-main">★ Main Character</span>
              )}
              {book.representationTypes.map((tag: string) => (
                <span class="tag">
                  {getTagIconSvg(tag) && <span class="tag-icon" aria-hidden="true" set:html={getTagIconSvg(tag)} />}
                  {tag}
                </span>
              ))}
              {book.equipment.map((tag: string) => (
                <span class="tag tag-equip">
                  {getTagIconSvg(tag) && <span class="tag-icon" aria-hidden="true" set:html={getTagIconSvg(tag)} />}
                  {tag}
                </span>
              ))}
              {book.tags.map((tag: string) => (
                <span class="tag tag-topic">{tag}</span>
              ))}
              {book.authorConnection.length > 0 && (
                <span class="tag tag-author">{book.authorConnection.join(', ')} Author</span>
              )}
              {book.illustratorConnection.length > 0 && (
                <span class="tag tag-author">{book.illustratorConnection.join(', ')} Illustrator</span>
              )}
              {book.languages.map((lang: string) => (
                <span class="tag tag-lang">{lang}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <p class="cta-text">Ready to find the perfect book?</p>
    <a href={`${base}/books`} class="cta-button cta-button-lg">
      Browse All {totalBooks} Books
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7.5 5L12.5 10L7.5 15"/>
      </svg>
    </a>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 3rem 1rem 2.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0 0 1rem;
    font-optical-sizing: auto;
  }

  .hero-text {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-ink-light);
    margin: 0 0 2rem;
  }

  .hero-text strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* CTA Button */
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    color: #fff;
    background: var(--color-teal);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  }

  .cta-button:hover {
    background: var(--color-teal-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(26, 138, 139, 0.3);
  }

  .cta-button:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cta-button-lg {
    padding: 0.85rem 2rem;
    font-size: 1.05rem;
  }

  /* Featured section */
  .featured {
    padding: 1rem 0 2rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
    text-align: center;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
    gap: 1.5rem;
  }

  /* Card styles — reuse catalog card design */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .book-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-card);
    transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.3, 1),
                box-shadow 0.25s cubic-bezier(0.2, 0.9, 0.3, 1),
                border-color 0.2s;
    animation: cardIn 0.4s ease both;
    position: relative;
  }

  .book-card:nth-child(1) { animation-delay: 0ms; }
  .book-card:nth-child(2) { animation-delay: 40ms; }
  .book-card:nth-child(3) { animation-delay: 80ms; }
  .book-card:nth-child(4) { animation-delay: 120ms; }
  .book-card:nth-child(5) { animation-delay: 160ms; }
  .book-card:nth-child(6) { animation-delay: 200ms; }
  .book-card:nth-child(7) { animation-delay: 240ms; }
  .book-card:nth-child(8) { animation-delay: 280ms; }

  .book-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, var(--color-navy), var(--color-teal));
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .book-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border);
  }

  .book-card:hover::before { opacity: 1; }

  .book-card:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .cover {
    aspect-ratio: 2 / 3;
    background: var(--color-cream-dark);
    overflow: hidden;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.3, 1);
  }

  .book-card:hover .cover img {
    transform: scale(1.03);
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-ink-muted);
    opacity: 0.4;
    background: linear-gradient(145deg, var(--color-cream-dark), var(--color-cream));
  }

  .info {
    padding: 0.875rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: var(--color-ink);
  }

  .card-author {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin: 0;
    font-weight: 400;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    margin-top: 0.1rem;
  }

  .dot {
    color: var(--color-border);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.35rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.675rem;
    font-weight: 500;
    font-family: var(--font-body);
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--color-teal-soft);
    color: var(--color-teal);
    letter-spacing: 0.01em;
  }

  .tag-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .tag-icon :global(svg) {
    display: block;
    width: 12px;
    height: 12px;
  }

  .tag-topic {
    background: var(--color-gold-soft);
    color: var(--color-gold);
  }

  .tag-equip {
    background: var(--color-plum-soft);
    color: var(--color-plum);
  }

  .tag-author {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .tag-lang {
    background: var(--color-rose-soft);
    color: var(--color-rose);
  }

  .tag-main {
    background: var(--color-navy);
    color: #fff;
  }

  /* Bottom CTA */
  .cta-section {
    text-align: center;
    padding: 2rem 1rem 3rem;
    border-top: 1px solid var(--color-border-light);
    margin-top: 1rem;
  }

  .cta-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  @media (max-width: 500px) {
    .hero {
      padding: 2rem 0.5rem 1.5rem;
    }

    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>
