---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getTagIconSvg } from '../../utils/tag-icons';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const coverEntries = await getCollection('covers');
  const coverMap = new Map(coverEntries.map(c => [c.id, c.data]));
  return books.map(entry => {
    const cover = coverMap.get(entry.id);
    return {
      params: { id: entry.id },
      props: {
        bookId: entry.id,
        book: {
          ...entry.data,
          coverImage: entry.data.coverImage || cover?.coverUrl || null,
        },
      },
    };
  });
}

const { bookId, book } = Astro.props;
const allReviews = await getCollection('reviews');
const bookReviews = allReviews.filter(r => r.data.bookId === bookId);
---

<Layout title={`${book.title} -- Hearing Center Book Catalogue`} showBackLink>
  <div class="book">
    <div class="cover-col">
      {book.coverImage
        ? <button class="cover-btn" type="button" aria-label="View larger cover image" data-open-lightbox>
            <img class="cover-img" src={book.coverImage} alt={`Cover of ${book.title}`} loading="lazy" />
          </button>
        : <div class="cover-placeholder">{book.title[0]}</div>
      }
    </div>

    {book.coverImage && (
      <dialog class="lightbox" data-lightbox>
        <button class="lightbox-close" type="button" aria-label="Close" data-close-lightbox>&times;</button>
        <img class="lightbox-img" src={book.coverImage} alt={`Cover of ${book.title}`} />
      </dialog>
    )}

    <div class="detail-col">
      <h1 class="title">{book.title}</h1>
      {book.author && <p class="author">by {book.author}</p>}
      {book.illustrator && <p class="illustrator">Illustrated by {book.illustrator}</p>}

      <dl class="fields">
        {book.bookType && (
          <>
            <dt>Book type</dt>
            <dd>{book.bookType}</dd>
          </>
        )}

        {book.ageRange && (
          <>
            <dt>Age range</dt>
            <dd>{book.ageRange}</dd>
          </>
        )}

        {book.publicationYear && (
          <>
            <dt>Published</dt>
            <dd>{book.publicationYear}</dd>
          </>
        )}

        {book.representationTypes.length > 0 && (
          <>
            <dt>Representation</dt>
            <dd>
              <div class="tags">
                {book.representationTypes.map((tag: string) => (
                  <span class="tag">
                    {getTagIconSvg(tag) && <span class="tag-icon" aria-hidden="true" set:html={getTagIconSvg(tag)} />}
                    {tag}
                  </span>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.equipment.length > 0 && (
          <>
            <dt>Equipment</dt>
            <dd>
              <div class="tags">
                {book.equipment.map((tag: string) => (
                  <span class="tag tag-equip">
                    {getTagIconSvg(tag) && <span class="tag-icon" aria-hidden="true" set:html={getTagIconSvg(tag)} />}
                    {tag}
                  </span>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.authorInfo && (
          <>
            <dt>Author connection</dt>
            <dd>{book.authorInfo}</dd>
          </>
        )}

        {book.libraryAvailable !== null && (
          <>
            <dt>Carnegie Library</dt>
            <dd class={book.libraryAvailable ? 'available' : ''}>
              {book.libraryAvailable ? 'Available' : 'Not listed'}
            </dd>
          </>
        )}
      </dl>

      {bookReviews.length > 0 && (
        <section class="reviews">
          <h2>What our friends say</h2>
          {bookReviews.map(review => (
            <div class="review">
              <div class="review-header">
                {review.data.photo && <img class="reviewer-photo" src={review.data.photo} alt={review.data.reviewer} />}
                <div>
                  <span class="reviewer-name">{review.data.reviewer}</span>
                  <span class="stars" aria-label={`${review.data.stars} out of 5 stars`}>
                    {'\u2605'.repeat(review.data.stars)}{'\u2606'.repeat(5 - review.data.stars)}
                  </span>
                </div>
              </div>
              <p class="review-text">{review.data.text}</p>
            </div>
          ))}
        </section>
      )}
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .book {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3rem;
    align-items: start;
    animation: slideUp 0.5s ease;
  }

  @media (max-width: 600px) {
    .book {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .cover-col {
      max-width: 240px;
    }
  }

  .cover-col {
    position: sticky;
    top: 5.5rem;
  }

  .cover-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    border-radius: var(--radius-lg);
  }

  .cover-btn:hover .cover-img {
    box-shadow: 0 8px 32px rgba(26, 26, 46, 0.2);
    transform: scale(1.01);
  }

  .cover-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 20px rgba(26, 26, 46, 0.12);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 2rem;
    border: none;
    background: rgba(26, 26, 46, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox:not([open]) {
    display: none;
  }

  .lightbox::backdrop {
    background: transparent;
  }

  .lightbox-img {
    min-width: 300px;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.4);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    transition: color 0.15s;
  }

  .lightbox-close:hover {
    color: #fff;
  }

  .cover-placeholder {
    width: 100%;
    aspect-ratio: 2 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 700;
    color: var(--color-ink-muted);
    opacity: 0.35;
    background: linear-gradient(145deg, var(--color-cream-dark), var(--color-cream));
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--color-border);
  }

  .detail-col {
    min-width: 0;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.4rem;
    line-height: 1.15;
    color: var(--color-ink);
    font-optical-sizing: auto;
  }

  .author {
    font-size: 1.05rem;
    color: var(--color-ink-muted);
    margin: 0 0 0.25rem;
    font-weight: 400;
  }

  .illustrator {
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin: 0 0 2rem;
    font-style: italic;
  }

  .author + .fields {
    margin-top: 2rem;
  }

  .fields {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.75rem 1.5rem;
    margin: 0;
    align-items: baseline;
  }

  dt {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
    white-space: nowrap;
    font-family: var(--font-body);
  }

  dd {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-ink-light);
  }

  dd.available {
    color: var(--color-teal);
    font-weight: 500;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.775rem;
    font-weight: 500;
    font-family: var(--font-body);
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: var(--color-teal-soft);
    color: var(--color-teal);
  }

  .tag-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .tag-icon :global(svg) {
    display: block;
    width: 14px;
    height: 14px;
  }

  .tag-equip {
    background: var(--color-plum-soft);
    color: var(--color-plum);
  }

  /* Reviews */
  .reviews {
    margin-top: 2.5rem;
    border-top: 1.5px solid var(--color-border-light);
    padding-top: 1.5rem;
  }

  .reviews h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .review {
    background: var(--color-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.75rem;
    box-shadow: var(--shadow-card);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .reviewer-photo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border-light);
  }

  .reviewer-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-ink);
    display: block;
  }

  .stars {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--color-teal-dark);
  }

  .review-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-ink-light);
    line-height: 1.6;
  }
</style>

<script>
  const openBtn = document.querySelector('[data-open-lightbox]');
  const dialog = document.querySelector('[data-lightbox]') as HTMLDialogElement | null;
  const closeBtn = document.querySelector('[data-close-lightbox]');

  if (openBtn && dialog) {
    openBtn.addEventListener('click', () => dialog.showModal());
    closeBtn?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
