---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getTagIconSvg } from '../../utils/tag-icons';
import { base } from '../../utils/url';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const metadataEntries = await getCollection('metadata');
  const metadataMap = new Map(metadataEntries.map(c => [c.id, c.data]));

  // Build a map of series name -> sorted list of books in that series
  const seriesMap = new Map<string, Array<{ id: string; title: string; seriesNumber: number | null; coverImage: string | null }>>();
  for (const entry of books) {
    const s = entry.data.series;
    if (!s) continue;
    if (!seriesMap.has(s)) seriesMap.set(s, []);
    const meta = metadataMap.get(entry.id);
    seriesMap.get(s)!.push({
      id: entry.id,
      title: entry.data.title,
      seriesNumber: entry.data.seriesNumber,
      coverImage: entry.data.coverImage || meta?.coverUrl || null,
    });
  }
  // Sort each series: numbered books first (by number), then unnumbered (by title)
  for (const list of seriesMap.values()) {
    list.sort((a, b) => {
      if (a.seriesNumber != null && b.seriesNumber != null) return a.seriesNumber - b.seriesNumber;
      if (a.seriesNumber != null) return -1;
      if (b.seriesNumber != null) return 1;
      return a.title.localeCompare(b.title);
    });
  }

  return books.map(entry => {
    const meta = metadataMap.get(entry.id);
    return {
      params: { id: entry.id },
      props: {
        bookId: entry.id,
        book: {
          ...entry.data,
          coverImage: entry.data.coverImage || meta?.coverUrl || null,
        },
        seriesBooks: entry.data.series ? seriesMap.get(entry.data.series)! : [],
      },
    };
  });
}

const { bookId, book, seriesBooks } = Astro.props;
const allReviews = await getCollection('reviews');
const bookReviews = allReviews.filter(r => r.data.bookId === bookId);
---

<Layout title={`${book.title} — Hearing Center Book Catalog`} showBackLink>
  <div class="book">
    <div class="cover-col">
      {book.coverImage
        ? <button class="cover-btn" type="button" aria-label="View larger cover image" data-open-lightbox>
            <img class="cover-img" src={book.coverImage} alt={`Cover of ${book.title}`} loading="lazy" />
          </button>
        : <div class="cover-placeholder">{book.title[0]}</div>
      }
    </div>

    {book.coverImage && (
      <dialog class="lightbox" data-lightbox>
        <button class="lightbox-close" type="button" aria-label="Close" data-close-lightbox>&times;</button>
        <img class="lightbox-img" src={book.coverImage} alt={`Cover of ${book.title}`} />
      </dialog>
    )}

    <div class="detail-col">
      <h1 class="title">{book.title}</h1>
      {book.author && <p class="author">by {book.author}</p>}
      {book.illustrator && <p class="illustrator">Illustrated by {book.illustrator}</p>}

      {book.summary && <p class="description">{book.summary}</p>}

      <dl class="fields">
        {book.bookType && (
          <>
            <dt>Book type</dt>
            <dd>{book.bookType}</dd>
          </>
        )}

        {book.ageGroups.length > 0 && (
          <>
            <dt>Age group</dt>
            <dd>
              <div class="tags">
                {book.ageGroups.map((ag: string) => (
                  <a class="tag tag-age" href={`${base}/books?age=${encodeURIComponent(ag)}`}>{ag}</a>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.mainCharacter && (
          <>
            <dt>Main character</dt>
            <dd>
              <span class="tag tag-main">★ Deaf/HoH/DeafBlind main character</span>
            </dd>
          </>
        )}

        {book.series && (
          <>
            <dt>Series</dt>
            <dd>{book.series}{book.seriesNumber ? ` (#${book.seriesNumber})` : ''} &middot; <a href="#series" class="series-link">See all {seriesBooks.length} books</a></dd>
          </>
        )}

        {book.publicationYear && (
          <>
            <dt>Published</dt>
            <dd>{book.publicationYear}</dd>
          </>
        )}

        {book.representationTypes.length > 0 && (
          <>
            <dt>Representation</dt>
            <dd>
              <div class="tags">
                {book.representationTypes.map((tag: string) => (
                  <a class="tag" href={`${base}/books?rep=${encodeURIComponent(tag)}`}>
                    {getTagIconSvg(tag) && <span class="tag-icon" aria-hidden="true" set:html={getTagIconSvg(tag)} />}
                    {tag}
                  </a>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.equipment.length > 0 && (
          <>
            <dt>Equipment</dt>
            <dd>
              <div class="tags">
                {book.equipment.map((tag: string) => (
                  <a class="tag tag-equip" href={`${base}/books?equip=${encodeURIComponent(tag)}`}>
                    {getTagIconSvg(tag) && <span class="tag-icon" aria-hidden="true" set:html={getTagIconSvg(tag)} />}
                    {tag}
                  </a>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.tags.length > 0 && (
          <>
            <dt>Topics</dt>
            <dd>
              <div class="tags">
                {book.tags.map((tag: string) => (
                  <a class="tag tag-topic" href={`${base}/books?tag=${encodeURIComponent(tag)}`}>{tag}</a>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.languages.length > 0 && (
          <>
            <dt>Languages available</dt>
            <dd>
              <div class="tags">
                {book.languages.map((lang: string) => (
                  <a class="tag tag-lang" href={`${base}/books?lang=${encodeURIComponent(lang)}`}>{lang}</a>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.authorConnection.length > 0 && (
          <>
            <dt>Author connection</dt>
            <dd>
              <div class="tags">
                {book.authorConnection.map((c: string) => (
                  <a class="tag tag-author" href={`${base}/books?author=${encodeURIComponent(c)}`}>{c}</a>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.illustratorConnection.length > 0 && (
          <>
            <dt>Illustrator connection</dt>
            <dd>
              <div class="tags">
                {book.illustratorConnection.map((c: string) => (
                  <span class="tag tag-author">{c}</span>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.carnegieLibraryLink && (
          <>
            <dt>Carnegie Library</dt>
            <dd class="available">
              <a href={book.carnegieLibraryLink} target="_blank" rel="noopener noreferrer">✓ Available</a>
            </dd>
          </>
        )}
      </dl>

      {book.purchaseLink && (
        <a class="purchase-link" href={book.purchaseLink} target="_blank" rel="noopener noreferrer">
          Find this book
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3H3v10h10V9"/><path d="M9 1h6v6"/><path d="M15 1L7 9"/></svg>
        </a>
      )}

      {seriesBooks.length > 1 && (
        <section class="series-section" id="series">
          <h2>More in the <em>{book.series}</em> series</h2>
          <ul class="series-list">
            {seriesBooks.map((sb: { id: string; title: string; seriesNumber: number | null; coverImage: string | null }) => (
              <li class:list={['series-item', { 'series-item--current': sb.id === bookId }]}>
                {sb.id === bookId ? (
                  <span class="series-card series-card--current" aria-current="true">
                    {sb.coverImage
                      ? <img class="series-cover" src={sb.coverImage} alt="" loading="lazy" />
                      : <span class="series-cover-placeholder">{sb.title[0]}</span>
                    }
                    <span class="series-info">
                      {sb.seriesNumber != null && <span class="series-number">#{sb.seriesNumber}</span>}
                      <span class="series-title">{sb.title}</span>
                      <span class="series-current-label">Current book</span>
                    </span>
                  </span>
                ) : (
                  <a class="series-card" href={`${base}/books/${sb.id}`}>
                    {sb.coverImage
                      ? <img class="series-cover" src={sb.coverImage} alt="" loading="lazy" />
                      : <span class="series-cover-placeholder">{sb.title[0]}</span>
                    }
                    <span class="series-info">
                      {sb.seriesNumber != null && <span class="series-number">#{sb.seriesNumber}</span>}
                      <span class="series-title">{sb.title}</span>
                    </span>
                  </a>
                )}
              </li>
            ))}
          </ul>
        </section>
      )}

      {bookReviews.length > 0 && (
        <section class="reviews">
          <h2>What our friends say</h2>
          {bookReviews.map(review => (
            <div class="review">
              <div class="review-header">
                {review.data.photo && <img class="reviewer-photo" src={review.data.photo} alt={review.data.reviewer} />}
                <div>
                  <span class="reviewer-name">{review.data.reviewer}</span>
                  <span class="stars" aria-label={`${review.data.stars} out of 5 stars`}>
                    {'\u2605'.repeat(review.data.stars)}{'\u2606'.repeat(5 - review.data.stars)}
                  </span>
                </div>
              </div>
              <p class="review-text">{review.data.text}</p>
            </div>
          ))}
        </section>
      )}
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .book {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3rem;
    align-items: start;
    animation: slideUp 0.5s ease;
  }

  @media (max-width: 600px) {
    .book {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .cover-col {
      max-width: 240px;
    }
  }

  .cover-col {
    position: sticky;
    top: 5.5rem;
  }

  .cover-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    border-radius: var(--radius-lg);
  }

  .cover-btn:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cover-btn:hover .cover-img {
    box-shadow: 0 8px 32px rgba(26, 26, 46, 0.2);
    transform: scale(1.01);
  }

  .cover-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 20px rgba(26, 26, 46, 0.12);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 2rem;
    border: none;
    background: rgba(26, 26, 46, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox:not([open]) {
    display: none;
  }

  .lightbox::backdrop {
    background: transparent;
  }

  .lightbox-img {
    min-width: 300px;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.4);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    transition: color 0.15s;
  }

  .lightbox-close:hover {
    color: #fff;
  }

  .lightbox-close:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .cover-placeholder {
    width: 100%;
    aspect-ratio: 2 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 700;
    color: var(--color-ink-muted);
    opacity: 0.35;
    background: linear-gradient(145deg, var(--color-cream-dark), var(--color-cream));
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--color-border);
  }

  .detail-col {
    min-width: 0;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.4rem;
    line-height: 1.15;
    color: var(--color-ink);
    font-optical-sizing: auto;
  }

  .author {
    font-size: 1.05rem;
    color: var(--color-ink-muted);
    margin: 0 0 0.25rem;
    font-weight: 400;
  }

  .illustrator {
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin: 0 0 2rem;
    font-style: italic;
  }

  .description {
    font-size: 0.95rem;
    color: var(--color-ink-light);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .author + .fields {
    margin-top: 2rem;
  }

  .fields {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.75rem 1.5rem;
    margin: 0;
    align-items: baseline;
  }

  dt {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
    white-space: nowrap;
    font-family: var(--font-body);
  }

  dd {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-ink-light);
  }

  dd.available {
    color: var(--color-teal);
    font-weight: 500;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.775rem;
    font-weight: 500;
    font-family: var(--font-body);
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: var(--color-teal-soft);
    color: var(--color-teal);
  }

  .tag-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .tag-icon :global(svg) {
    display: block;
    width: 14px;
    height: 14px;
  }

  .tag-topic {
    background: var(--color-gold-soft);
    color: var(--color-gold);
  }

  .tag-equip {
    background: var(--color-plum-soft);
    color: var(--color-plum);
  }

  .tag-lang {
    background: var(--color-rose-soft);
    color: var(--color-rose);
  }

  .tag-author {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .tag-age {
    background: var(--color-navy-soft);
    color: var(--color-navy);
  }

  .tag-main {
    background: var(--color-navy);
    color: #fff;
  }

  a.tag {
    text-decoration: none;
    transition: filter 0.15s, transform 0.15s, box-shadow 0.15s;
  }

  a.tag:hover {
    filter: brightness(0.94);
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(26, 26, 46, 0.12);
  }

  a.tag:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Series inline link */
  .series-link {
    color: var(--color-teal);
    text-decoration: none;
    font-weight: 500;
  }

  .series-link:hover {
    text-decoration: underline;
  }

  /* Series section */
  .series-section {
    margin-top: 2.5rem;
    border-top: 1.5px solid var(--color-border-light);
    padding-top: 1.5rem;
  }

  .series-section h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .series-section h2 em {
    font-style: italic;
  }

  .series-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .series-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
    background: var(--color-card);
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  a.series-card:hover {
    border-color: var(--color-teal);
    box-shadow: 0 2px 8px rgba(26, 26, 46, 0.08);
  }

  a.series-card:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .series-card--current {
    border-color: var(--color-teal);
    background: var(--color-teal-soft);
  }

  .series-cover {
    width: 40px;
    height: 56px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .series-cover-placeholder {
    width: 40px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-ink-muted);
    opacity: 0.35;
    background: linear-gradient(145deg, var(--color-cream-dark), var(--color-cream));
    border-radius: 4px;
    flex-shrink: 0;
  }

  .series-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .series-number {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-teal);
  }

  .series-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .series-current-label {
    font-size: 0.7rem;
    color: var(--color-teal-dark);
    font-weight: 500;
  }

  /* Purchase link */
  .purchase-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
    padding: 0.6rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-body);
    color: #fff;
    background: var(--color-teal);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s, transform 0.15s;
  }

  .purchase-link:hover {
    background: var(--color-teal-dark);
    transform: translateY(-1px);
  }

  .purchase-link:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Reviews */
  .reviews {
    margin-top: 2.5rem;
    border-top: 1.5px solid var(--color-border-light);
    padding-top: 1.5rem;
  }

  .reviews h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .review {
    background: var(--color-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.75rem;
    box-shadow: var(--shadow-card);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .reviewer-photo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border-light);
  }

  .reviewer-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-ink);
    display: block;
  }

  .stars {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--color-teal-dark);
  }

  .review-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-ink-light);
    line-height: 1.6;
  }
</style>

<script>
  const openBtn = document.querySelector('[data-open-lightbox]');
  const dialog = document.querySelector('[data-lightbox]') as HTMLDialogElement | null;
  const closeBtn = document.querySelector('[data-close-lightbox]');

  if (openBtn && dialog) {
    openBtn.addEventListener('click', () => dialog.showModal());
    closeBtn?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
