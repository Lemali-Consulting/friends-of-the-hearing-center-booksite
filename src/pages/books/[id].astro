---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const coverEntries = await getCollection('covers');
  const coverMap = new Map(coverEntries.map(c => [c.id, c.data]));
  return books.map(entry => {
    const cover = coverMap.get(entry.id);
    return {
      params: { id: entry.id },
      props: {
        bookId: entry.id,
        book: {
          ...entry.data,
          coverImage: entry.data.coverImage || cover?.coverUrl || null,
        },
      },
    };
  });
}

const { bookId, book } = Astro.props;
const allReviews = await getCollection('reviews');
const bookReviews = allReviews.filter(r => r.data.bookId === bookId);
---

<Layout title={`${book.title} -- Friends of the Hearing Center`} showBackLink>
  <div class="book">
    <div class="cover-col">
      {book.coverImage
        ? <button class="cover-btn" type="button" aria-label="View larger cover image" data-open-lightbox>
            <img class="cover-img" src={book.coverImage} alt={`Cover of ${book.title}`} loading="lazy" />
          </button>
        : <div class="cover-placeholder">{book.title[0]}</div>
      }
    </div>

    {book.coverImage && (
      <dialog class="lightbox" data-lightbox>
        <button class="lightbox-close" type="button" aria-label="Close" data-close-lightbox>&times;</button>
        <img class="lightbox-img" src={book.coverImage} alt={`Cover of ${book.title}`} />
      </dialog>
    )}

    <div class="detail-col">
      <h1 class="title">{book.title}</h1>
      {book.author && <p class="author">by {book.author}</p>}
      {book.illustrator && <p class="illustrator">Illustrated by {book.illustrator}</p>}

      <dl class="fields">
        {book.bookType && (
          <>
            <dt>Book type</dt>
            <dd>{book.bookType}</dd>
          </>
        )}

        {book.ageRange && (
          <>
            <dt>Age range</dt>
            <dd>{book.ageRange}</dd>
          </>
        )}

        {book.publicationYear && (
          <>
            <dt>Published</dt>
            <dd>{book.publicationYear}</dd>
          </>
        )}

        {book.representationTypes.length > 0 && (
          <>
            <dt>Representation</dt>
            <dd>
              <div class="tags">
                {book.representationTypes.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.equipment.length > 0 && (
          <>
            <dt>Equipment</dt>
            <dd>
              <div class="tags">
                {book.equipment.map((tag: string) => (
                  <span class="tag tag-equip">{tag}</span>
                ))}
              </div>
            </dd>
          </>
        )}

        {book.authorInfo && (
          <>
            <dt>Author connection</dt>
            <dd>{book.authorInfo}</dd>
          </>
        )}

        {book.libraryAvailable !== null && (
          <>
            <dt>Carnegie Library</dt>
            <dd>{book.libraryAvailable ? 'Available' : 'Not listed'}</dd>
          </>
        )}
      </dl>

      {bookReviews.length > 0 && (
        <section class="reviews">
          <h2>What our friends say</h2>
          {bookReviews.map(review => (
            <div class="review">
              <div class="review-header">
                {review.data.photo && <img class="reviewer-photo" src={review.data.photo} alt={review.data.reviewer} />}
                <div>
                  <span class="reviewer-name">{review.data.reviewer}</span>
                  <span class="stars" aria-label={`${review.data.stars} out of 5 stars`}>
                    {'\u2605'.repeat(review.data.stars)}{'\u2606'.repeat(5 - review.data.stars)}
                  </span>
                </div>
              </div>
              <p class="review-text">{review.data.text}</p>
            </div>
          ))}
        </section>
      )}
    </div>
  </div>
</Layout>

<style>
  .book {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .book {
      grid-template-columns: 1fr;
    }
  }

  .cover-col {
    position: sticky;
    top: 1.5rem;
  }

  .cover-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    border-radius: 8px;
  }

  .cover-btn:hover .cover-img {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
  }

  .cover-img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    transition: box-shadow 0.2s ease;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 2rem;
    border: none;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox:not([open]) {
    display: none;
  }

  .lightbox::backdrop {
    background: transparent;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    opacity: 0.8;
    transition: opacity 0.15s;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .cover-placeholder {
    width: 100%;
    aspect-ratio: 2 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: 700;
    color: #6b7280;
    background: #f3f4f6;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
  }

  .detail-col {
    min-width: 0;
  }

  .title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    line-height: 1.2;
  }

  .author {
    font-size: 1.05rem;
    color: #6b7280;
    margin: 0 0 0.25rem;
  }

  .illustrator {
    font-size: 0.95rem;
    color: #6b7280;
    margin: 0 0 2rem;
  }

  .author + .fields {
    margin-top: 2rem;
  }

  .fields {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.6rem 1.5rem;
    margin: 0;
    align-items: baseline;
  }

  dt {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    white-space: nowrap;
  }

  dd {
    margin: 0;
    font-size: 0.95rem;
    color: #374151;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: #e8f8f8;
    color: #0c6b6c;
  }

  .tag-equip {
    background: #f3e8ff;
    color: #7b2fbe;
  }

  /* Reviews */
  .reviews {
    margin-top: 2.5rem;
    border-top: 1px solid #e5e7eb;
    padding-top: 1.5rem;
  }

  .reviews h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: #111827;
  }

  .review {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .reviewer-photo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
  }

  .reviewer-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: #111827;
    display: block;
  }

  .stars {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: #6ECFD0;
  }

  .review-text {
    margin: 0;
    font-size: 0.9rem;
    color: #374151;
    line-height: 1.5;
  }
</style>

<script>
  const openBtn = document.querySelector('[data-open-lightbox]');
  const dialog = document.querySelector('[data-lightbox]') as HTMLDialogElement | null;
  const closeBtn = document.querySelector('[data-close-lightbox]');

  if (openBtn && dialog) {
    openBtn.addEventListener('click', () => dialog.showModal());
    closeBtn?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
